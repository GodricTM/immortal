<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Runs on both touch Portals and the Portal TV (Leanback). Neither feature is
         required, so the app installs on every model. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <!-- Camera is not required — the button gracefully hides if unavailable. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Camera preview button: show live camera feed. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Calendar widget: read upcoming events from the device calendar. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <!-- System-wide back-swipe gesture: draw a transparent overlay on the
         right edge of the screen. The user must grant "Draw over other apps"
         at runtime. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- The overlay back-gesture service runs in the background so the swipe
         works in any app. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Store: install and remove apps on-device via PackageInstaller. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <!-- Self-healing: reaffirm our screensaver settings if something resets them.
         Not granted at install (privileged); provisioning grants it via
         `pm grant ... WRITE_SECURE_SETTINGS`. Harmless no-op if not granted. -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- "Install an APK" browser: list APKs the user downloaded. Pre-granted by
         the provisioning kit; also requested at runtime. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Stats widget: IP address from Wi-Fi connection info. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Header volume button: adjust media volume. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- "Leave a note" voice memo: record a short message from the handset mic. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- "hey" trigger guard. Millennium's TriggerReceiver requires this permission, so only
         the launcher may fire the push-to-talk trigger (not arbitrary apps). It's signature-
         level and DEFINED HERE (the sender) on purpose: Immortal and Millennium are signed with
         different keys, so a signature permission defined by Millennium couldn't be held by us.
         Defining it on the sender means only Immortal-signed apps hold it -> only we can trigger. -->
    <permission
        android:name="com.immortal.launcher.permission.HEY_TRIGGER"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.immortal.launcher.permission.HEY_TRIGGER" />

    <application
        android:name=".ImmortalApp"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.SampleApp">

        <!-- Immortal launcher. Eligible as the system home (HOME filter) for the
             optional `cmd package set-home-activity` step. Its "Calls" tile
             bridges to the stock launcher, so nothing is hijacked.

             The drawer/app-grid entry (LAUNCHER filter) lives on the alias below
             rather than here: the Portal TV's stock home (ripleyhome) hides apps
             that carry CATEGORY_HOME from its grid, so a launcher that's also a
             home app would never show. The alias is a plain LAUNCHER app (no HOME
             category) that just opens this activity, so it appears like VLC etc. -->
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SampleApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Plain "open Immortal" app entry for stock launchers, and an Android-TV
             (Leanback) entry so it shows on the Portal TV's stock home, ripleyhome.
             ripleyhome is a TV launcher: it lists apps with LEANBACK_LAUNCHER (VLC,
             the Vewd browser, …), not plain LAUNCHER, which is why Immortal didn't
             appear there. This alias has only those launcher categories — no HOME —
             so it isn't filtered as a home app, and a 320x180 banner is provided for
             the TV card. It just opens HomeActivity. -->
        <activity-alias
            android:name=".ImmortalAppEntry"
            android:exported="true"
            android:targetActivity=".HomeActivity"
            android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:banner="@drawable/immortal_banner">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- App Store, launched internally from the launcher tile (explicit
             intent), so it isn't exported. -->
        <activity
            android:name=".StoreActivity"
            android:exported="false"
            android:label="App Store"
            android:theme="@style/Theme.SampleApp" />

        <!-- Full-screen photo frame: on-demand preview AND the permanent frame
             DreamPolicy relaunches when the system force-wakes the screensaver.
             Excluded from recents — it's ambient, not a task. -->
        <activity
            android:name=".PhotoFramePreviewActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SampleApp" />

        <!-- Camera preview: full-screen live camera feed, opened from the
             Camera tile in the launcher. Excluded from recents. -->
        <activity
            android:name=".CameraPreviewActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.SampleApp" />

        <!-- Screensaver settings (source folder/USB, fit, interval, …), opened from
             the Screensaver tile in the launcher's Settings folder. -->
        <activity
            android:name=".ScreensaverSettingsActivity"
            android:exported="false"
            android:label="Screensaver"
            android:theme="@style/Theme.SampleApp" />

        <!-- Welcome overlay settings (greetings, colors, sizes, duration), opened from
             the Welcome tile in the launcher's Settings folder. -->
        <activity
            android:name=".WelcomeSettingsActivity"
            android:exported="false"
            android:label="Welcome"
            android:theme="@style/Theme.SampleApp" />

        <!-- Sleep timer settings, opened from the Sleep tile in the launcher's Settings folder. -->
        <activity
            android:name=".SleepSettingsActivity"
            android:exported="false"
            android:label="Sleep"
            android:theme="@style/Theme.SampleApp" />

        <!-- Ambient sound cues (hourly chime, spoken time, golden-hour tone, quiet
             hours), opened from the Sounds tile in the launcher's Settings folder. -->
        <activity
            android:name=".ChimeSettingsActivity"
            android:exported="false"
            android:label="Sounds"
            android:theme="@style/Theme.SampleApp" />

        <!-- Countdown chips (birthdays, trips, holidays), opened from the Countdowns
             tile in the launcher's Settings folder. -->
        <activity
            android:name=".CountdownSettingsActivity"
            android:exported="false"
            android:label="Countdowns"
            android:theme="@style/Theme.SampleApp" />

        <!-- RTSP camera viewer, opened from the Cameras tile in the Settings folder. -->
        <activity
            android:name=".CameraViewerActivity"
            android:exported="false"
            android:label="Cameras"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.SampleApp" />

        <!-- LAN intercom / baby monitor, opened from the Intercom tile in Settings. -->
        <activity
            android:name=".IntercomActivity"
            android:exported="false"
            android:label="Intercom"
            android:theme="@style/Theme.SampleApp" />

        <!-- Clock settings (digital clock style, color, font, size, layout, background,
             glow, show date, show seconds, screensaver activation), opened from the
             Clock tile in the launcher's Settings folder. -->
        <activity
            android:name=".ClockSettingsActivity"
            android:exported="false"
            android:label="Clock"
            android:theme="@style/Theme.SampleApp" />

        <!-- Full-screen digital clock preview, opened from the Preview button in
             Clock settings. Excluded from recents. -->
        <activity
            android:name=".DigitalClockPreviewActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.SampleApp" />

        <!-- Immortal's own settings (weather unit, home-screen forecast widget, tile
             size), opened from the Immortal tile in the launcher's Settings folder. -->
        <activity
            android:name=".ImmortalSettingsActivity"
            android:exported="false"
            android:label="Immortal Settings"
            android:theme="@style/Theme.SampleApp" />

        <!-- Friendly, non-technical guided tour. Opened from the Help tile and once
             automatically on first launch. -->
        <activity
            android:name=".HelpActivity"
            android:exported="false"
            android:label="Help"
            android:theme="@style/Theme.SampleApp" />

        <!-- In-app folder browser for picking a screensaver source (the Portal has
             no system document picker), reachable from the screensaver settings. -->
        <activity
            android:name=".FolderPickerActivity"
            android:exported="false"
            android:label="Choose a folder"
            android:theme="@style/Theme.SampleApp" />

        <!-- "Install an APK" file browser, opened from the App Store. -->
        <activity
            android:name=".ApkBrowserActivity"
            android:exported="false"
            android:label="Install an APK"
            android:theme="@style/Theme.SampleApp" />

        <!-- "Open with Immortal" for any .apk the user taps (Chrome download,
             file manager, etc.) — routes the install through the silent daemon,
             so sideloading works even where the stock installer is broken. -->
        <activity
            android:name=".ApkInstallActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:label="Install with Immortal"
            android:theme="@style/Theme.SampleApp">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/vnd.android.package-archive" />
                <data android:scheme="file" android:mimeType="application/vnd.android.package-archive" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.INSTALL_PACKAGE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:scheme="file" />
            </intent-filter>
        </activity>

        <!-- Reaffirm our screensaver settings after boot (self-healing). -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Device admin (force-lock only): lets Immortal turn the screen off for the
             idle-timeout and overnight-sleep features via lockNow(). Activated by
             provisioning with `dpm set-active-admin`; a no-op until then. -->
        <receiver
            android:name=".AdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- System-wide "Go back" accessibility service. User enables once in
             Android Settings → Accessibility, then it exposes a global BACK
             action in the accessibility navigation bar. -->
        <service
            android:name=".ImmortalBackGestureService"
            android:exported="true"
            android:label="@string/back_gesture_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/back_gesture_service_config" />
        </service>

        <!-- System-wide back-swipe gesture via a transparent overlay. Runs as
             a foreground service and draws a thin strip on the right edge
             that detects leftward swipes. Requires SYSTEM_ALERT_WINDOW. -->
        <service
            android:name=".SystemBackGestureService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="System-wide back-swipe gesture overlay" />
        </service>

        <!-- Internal alarms for the idle and overnight screen-off features. -->
        <receiver
            android:name=".SleepReceiver"
            android:exported="false" />

        <!-- Internal alarms for the ambient audio cues (hourly chime, spoken time,
             golden-hour tone). -->
        <receiver
            android:name=".ChimeReceiver"
            android:exported="false" />

        <!-- Internal alarms for the kitchen multi-timers (ring when each elapses). -->
        <receiver
            android:name=".TimerReceiver"
            android:exported="false" />

        <!-- Notification listener used only to read the active media session for the
             now-playing screensaver. The user enables it once in Settings → Notifications.
             It reads nothing else. -->
        <service
            android:name=".NowPlayingListenerService"
            android:exported="false"
            android:label="Immortal Now Playing"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Custom screensaver (Dream), set via secure setting screensaver_components. -->
        <service
            android:name=".PhotoDreamService"
            android:exported="true"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <!-- Digital clock screensaver (Dream), alternative to the photo frame. -->
        <service
            android:name=".DigitalClockDreamService"
            android:exported="true"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>
    </application>

</manifest>
