<resources>

    <style name="Theme.SampleApp" parent="android:Theme.Material.NoActionBar">
        <!-- Dark window chrome so the status bar never flashes white before
             Compose renders or when it transiently reappears on swipe. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
